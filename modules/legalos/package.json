{
  "name": "woxox-legalos",
  "version": "1.0.0",
  "private": true,
  "description": "WOXOX LegalOS for India — native Legal Practice Management module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:api": "npm run dev -w @woxox/legalos-api",
    "dev:web": "npm run dev -w @woxox/legalos-web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "mint-jwt": "node scripts/mint-jwt.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
