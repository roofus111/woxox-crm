  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type": "module",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "build:icons": "tsx src/assets/iconify-icons/bundle-icons-css.js",
    "migrate": "dotenv -e .env -- npx prisma migrate dev",
    "postinstall": "prisma generate && npm run build:icons",
    "removeI18n": "tsx src/remove-translation-scripts/index.js",
    "legalos:install": "npm install --prefix modules/legalos",
    "legalos:api": "npm run dev:api --prefix modules/legalos",
    "legalos:web": "npm run dev:web --prefix modules/legalos",
    "legalos:typecheck": "npm run typecheck --prefix modules/legalos",
    "platform:up": "docker compose -f platform/docker-compose.yml up -d",
    "platform:down": "docker compose -f platform/docker-compose.yml down",
    "crm-api:install": "npm install --prefix platform/crm-api",
    "crm-api:dev": "npm run start:dev --prefix platform/crm-api",
    "crm-api:migrate": "npm run prisma:migrate --prefix platform/crm-api",
    "crm-api:seed": "npm run db:seed --prefix platform/crm-api"
  },
