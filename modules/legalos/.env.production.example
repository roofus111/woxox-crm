# LegalOS — production template (copy to .env and fill secrets)
NODE_ENV=production
PORT=4000
LEGALOS_ENABLED=true
LEGALOS_USE_MEMORY_MONGO=false
LEGALOS_SEED_DEMO=false
LEGALOS_REQUIRE_S3=true

MONGODB_URI=mongodb://mongo:27017/woxox_legalos

# REQUIRED — min 32 characters
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_ISSUER=woxox
JWT_AUDIENCE=legalos
WORKSPACE_AUTH_MODE=claim

CORS_ORIGIN=https://legal.your-domain.com
TRUST_PROXY=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

S3_BUCKET=woxox-legalos-prod
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

OPENAI_API_KEY=
LEGALOS_AI_MODEL=gpt-4o-mini

# Web build args / runtime public config
NEXT_PUBLIC_API_BASE_URL=https://api.your-domain.com/api/v1/legal
NEXT_PUBLIC_LEGALOS_BEARER_TOKEN=
NEXT_PUBLIC_WORKSPACE_ID=
NEXT_PUBLIC_ALLOW_MOCKS=false
