// WOXOX CRM — PostgreSQL schema (multi-tenant, row-level isolation via workspaceId)
// Phase 1: Core CRM entities. Expand per module in later migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenancy & identity ─────────────────────────────────────────────────────

model Workspace {
  id                 String    @id @default(cuid())
  name               String
  slug               String    @unique
  tenantCode         String?   @unique
  plan               String    @default("starter")
  status             String    @default("active") // active | suspended | trial
  trialEndsAt        DateTime?
  enabledModules     String[]  @default(["crm"])
  settings           Json      @default("{}")
  ownerUserId        String?
  accountManagerNote String?
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  users                 WorkspaceMember[]
  leads                 Lead[]
  contacts              Contact[]
  companies             Company[]
  deals                 Deal[]
  pipelines             Pipeline[]
  activities            Activity[]
  tasks                 Task[]
  auditLogs             AuditLog[]
  platformAudits        PlatformAuditLog[]
  impersonationSessions ImpersonationSession[]
  subscriptions         Subscription[]
  invoices              Invoice[]

  @@index([status])
  @@index([plan])
  @@index([deletedAt])
  @@index([createdAt])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  avatarUrl     String?
  emailVerified DateTime?
  twoFactorEnabled Boolean @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships              WorkspaceMember[]
  auditLogs                AuditLog[]
  platformAudits           PlatformAuditLog[]
  impersonationsAsActor    ImpersonationSession[] @relation("ImpersonationActor")
  impersonationsAsTarget   ImpersonationSession[] @relation("ImpersonationTarget")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role     @default(USER)
  permissions Json     @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  USER
  FINANCE
  PIPELINE
  GUEST
}

// ─── Lead management ────────────────────────────────────────────────────────

model Lead {
  id           String     @id @default(cuid())
  workspaceId  String
  title        String?
  firstName    String?
  lastName     String?
  email        String?
  phone        String?
  companyName  String?
  source       LeadSource @default(MANUAL)
  status       LeadStatus @default(NEW)
  score        Int        @default(0)
  ownerId      String?
  tags         String[]   @default([])
  customFields Json       @default("{}")
  geoLocation  Json?
  convertedAt  DateTime?
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  activities Activity[]
  deals      Deal[]

  @@index([workspaceId, status])
  @@index([workspaceId, email])
  @@index([workspaceId, ownerId])
  @@index([workspaceId, createdAt])
}

enum LeadSource {
  MANUAL
  WEBSITE
  LANDING_PAGE
  FACEBOOK
  GOOGLE_ADS
  WHATSAPP
  EMAIL
  API
  CSV_IMPORT
  REFERRAL
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  NURTURING
  CONVERTED
  LOST
}

// ─── Contacts & companies ───────────────────────────────────────────────────

model Contact {
  id           String    @id @default(cuid())
  workspaceId  String
  companyId    String?
  firstName    String
  lastName     String?
  emails       String[]  @default([])
  phones       String[]  @default([])
  jobTitle     String?
  socialProfiles Json    @default("{}")
  customFields Json      @default("{}")
  ownerId      String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  activities Activity[]
  deals      Deal[]

  @@index([workspaceId])
  @@index([workspaceId, companyId])
}

model Company {
  id           String    @id @default(cuid())
  workspaceId  String
  name         String
  industry     String?
  website      String?
  revenue      Decimal?  @db.Decimal(18, 2)
  employeeCount Int?
  addresses    Json      @default("[]")
  customFields Json      @default("{}")
  ownerId      String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts  Contact[]
  deals     Deal[]

  @@index([workspaceId])
  @@index([workspaceId, name])
}

// ─── Deals & pipeline ───────────────────────────────────────────────────────

model Pipeline {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stages    PipelineStage[]
  deals     Deal[]

  @@index([workspaceId])
}

model PipelineStage {
  id          String   @id @default(cuid())
  pipelineId  String
  name        String
  probability Int      @default(0)
  sortOrder   Int      @default(0)
  isWon       Boolean  @default(false)
  isLost      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@index([pipelineId, sortOrder])
}

model Deal {
  id              String    @id @default(cuid())
  workspaceId     String
  pipelineId      String?
  stageId         String?
  leadId          String?
  contactId       String?
  companyId       String?
  title           String
  amount          Decimal   @default(0) @db.Decimal(18, 2)
  currency        String    @default("INR")
  probability     Int       @default(0)
  expectedCloseAt DateTime?
  closedAt        DateTime?
  wonReason       String?
  lostReason      String?
  ownerId         String?
  customFields    Json      @default("{}")
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipeline  Pipeline?      @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  stage     PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  lead      Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact   Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company   Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  activities Activity[]

  @@index([workspaceId, stageId])
  @@index([workspaceId, ownerId])
  @@index([workspaceId, expectedCloseAt])
}

// ─── Activities & tasks ─────────────────────────────────────────────────────

model Activity {
  id          String       @id @default(cuid())
  workspaceId String
  type        ActivityType
  subject     String
  body        String?
  dueAt       DateTime?
  completedAt DateTime?
  ownerId     String?
  leadId      String?
  contactId   String?
  dealId      String?
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact   Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal      Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([workspaceId, type])
  @@index([workspaceId, dueAt])
}

enum ActivityType {
  CALL
  MEETING
  EMAIL
  WHATSAPP
  TASK
  NOTE
  SITE_VISIT
  VIDEO_CALL
  VOICE_NOTE
}

model Task {
  id          String     @id @default(cuid())
  workspaceId String
  title       String
  description String?
  status      TaskStatus @default(OPEN)
  priority    TaskPriority @default(MEDIUM)
  dueAt       DateTime?
  ownerId     String?
  assigneeId  String?
  parentId    String?
  checklist   Json       @default("[]")
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([workspaceId, assigneeId])
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Security & audit ───────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String?
  action      String
  entity      String
  entityId    String?
  ipAddress   String?
  userAgent   String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, entity, entityId])
}

/// Global Super Admin / control-plane audit trail
model PlatformAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  action      String
  entityType  String
  entityId    String?
  workspaceId String?
  ipAddress   String?
  userAgent   String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  actor     User?      @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([workspaceId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model ImpersonationSession {
  id          String    @id @default(cuid())
  actorUserId String
  targetUserId String
  workspaceId String
  expiresAt   DateTime
  revokedAt   DateTime?
  ipAddress   String?
  createdAt   DateTime  @default(now())

  actor     User      @relation("ImpersonationActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  target    User      @relation("ImpersonationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([actorUserId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([expiresAt])
}

// ─── Billing & subscriptions (control plane) ────────────────────────────────

model Plan {
  id                 String   @id @default(cuid())
  code               String   @unique
  name               String
  description        String?
  currency           String   @default("INR")
  amountMonthly      Int      @default(0) // minor units (paise/cents)
  amountYearly       Int      @default(0)
  enabledModules     String[] @default(["crm"])
  maxUsers           Int?
  maxStorageGb       Int?
  trialDays          Int      @default(14)
  stripePriceMonthly String?
  stripePriceYearly  String?
  razorpayPlanIdMonthly String?
  razorpayPlanIdYearly  String?
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  subscriptions Subscription[]

  @@index([isActive, sortOrder])
}

model Subscription {
  id                   String    @id @default(cuid())
  workspaceId          String
  planId               String
  status               String    @default("trialing") // trialing | active | past_due | canceled | unpaid
  billingCycle         String    @default("monthly") // monthly | yearly
  currentPeriodStart   DateTime  @default(now())
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  canceledAt           DateTime?
  trialEndsAt          DateTime?
  couponCode           String?
  stripeCustomerId     String?
  stripeSubscriptionId String?   @unique
  razorpayCustomerId   String?
  razorpaySubscriptionId String? @unique
  metadata             Json      @default("{}")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planId], references: [id])
  invoices  Invoice[]

  @@index([workspaceId, status])
  @@index([status])
  @@index([planId])
  @@index([currentPeriodEnd])
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String?
  percentOff      Int? // 1-100
  amountOff       Int? // minor units
  currency        String    @default("INR")
  maxRedemptions  Int?
  timesRedeemed   Int       @default(0)
  redeemBy        DateTime?
  durationMonths  Int? // null = once
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive])
}

model Invoice {
  id               String    @id @default(cuid())
  workspaceId      String
  subscriptionId   String?
  number           String?   @unique
  amountDue        Int       @default(0)
  amountPaid       Int       @default(0)
  currency         String    @default("INR")
  status           String    @default("draft") // draft | open | paid | void | uncollectible
  stripeInvoiceId  String?   @unique
  razorpayOrderId  String?   @unique
  razorpayPaymentId String?  @unique
  hostedInvoiceUrl String?
  pdfUrl           String?
  periodStart      DateTime?
  periodEnd        DateTime?
  paidAt           DateTime?
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([status, createdAt])
}

/// Stripe webhook idempotency
model StripeEvent {
  id          String   @id // Stripe event id evt_...
  type        String
  processedAt DateTime @default(now())
  payload     Json     @default("{}")

  @@index([type, processedAt])
}

/// Razorpay webhook idempotency
model RazorpayEvent {
  id          String   @id // Razorpay event id or payment/order id key
  type        String
  processedAt DateTime @default(now())
  payload     Json     @default("{}")

  @@index([type, processedAt])
}
