# -----------------------------------------------------------------------------
# WOXOX CRM — production (AWS EC2 / Docker Compose)
# Copy to .env.production and fill in real values before deploy.
# -----------------------------------------------------------------------------

# Public URLs (used by browser + Next.js build)
# HTTPS (production with domain):
# APP_ORIGIN=https://app.yourdomain.com
# API_ORIGIN=https://api.yourdomain.com
# PLATFORM_API_ORIGIN=https://platform.yourdomain.com
# WEBSITE_ORIGIN=https://www.yourdomain.com
# CORS_ORIGIN=https://app.yourdomain.com,https://www.yourdomain.com,https://yourdomain.com
#
# HTTP-only first test (single EC2 IP, no TLS yet):
APP_ORIGIN=http://YOUR_EC2_IP
API_ORIGIN=http://YOUR_EC2_IP/legacy-api
PLATFORM_API_ORIGIN=http://YOUR_EC2_IP/platform-api
WEBSITE_ORIGIN=http://YOUR_EC2_IP
# Comma-separated browser origins allowed to call crm-api (app + marketing)
CORS_ORIGIN=http://YOUR_EC2_IP

# Optional LegalOS (enable when deployed)
# LEGALOS_API_ORIGIN=https://legalos-api.yourdomain.com
# LEGALOS_WEB_ORIGIN=https://legalos.yourdomain.com

# Auth secrets (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=change-me-generate-with-openssl
JWT_SECRET=change-me-generate-with-openssl
# Optional: defaults to JWT_SECRET if empty
REFRESH_TOKEN_SECRET=
PLATFORM_JWT_SECRET=

# Postgres
POSTGRES_USER=woxox
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=woxox_crm

# Platform API
SEED_PLATFORM_DB=true
NEXT_PUBLIC_USE_CRM_PLATFORM_DASHBOARD=true

# crmserver repo path on server (sibling folder by default)
CRMSERVER_PATH=../crmserver

# TLS certs for nginx (Let's Encrypt or ACM-exported PEMs)
# Place fullchain.pem + privkey.pem in this folder
SSL_CERT_PATH=./deploy/aws/certs

# LegalOS bridge (if using LegalOS module)
CRM_BRIDGE_SECRET=change-me-bridge-secret

# Super Admin tenant provisioning (shared by crm-api + crmserver)
SUPER_ADMIN_PROVISION_SECRET=change-me-super-admin-secret

# Optional Stripe (billing webhooks). Leave empty for manual plan assign only.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook URL: https://platform.woxox.com/api/v1/billing/webhooks/stripe
# (or via app proxy if configured)

# Razorpay (India payments) — preferred for INR
# RAZORPAY_KEY_ID=rzp_live_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...   # from Razorpay Dashboard → Webhooks (not the API secret)
# Webhook URL: https://platform.woxox.com/api/v1/billing/webhooks/razorpay
# Events: payment.captured, order.paid, payment_link.paid, payment.failed

# SMTP (welcome + invite emails). Leave empty to skip sending (logged only).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@woxox.com
# SMTP_PASS=...
# SMTP_FROM="WOXOX <noreply@woxox.com>"

# Marketing website (sibling repo) + contact leads
# WEBSITE_PATH=../woxox-website
# MARKETING_WORKSPACE_ID=   # workspace that receives website contact leads
# MARKETING_NOTIFY_EMAIL=sales@woxox.com
