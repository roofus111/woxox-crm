# LegalOS — local development
LEGALOS_ENABLED=true
LEGALOS_USE_MEMORY_MONGO=true
LEGALOS_SEED_DEMO=true
LEGALOS_PROVIDER_ECOURTS_ENABLED=false
LEGALOS_PROVIDER_SCC_ENABLED=false
LEGALOS_PROVIDER_MANUPATRA_ENABLED=false
LEGALOS_MAX_UPLOAD_BYTES=104857600
LEGALOS_EVIDENCE_HASH_ALGORITHM=sha256
LEGALOS_REQUIRE_S3=false

# API
PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/woxox_legalos
JWT_SECRET=change-me-in-production
JWT_ISSUER=
JWT_AUDIENCE=
WORKSPACE_AUTH_MODE=header
CORS_ORIGIN=http://localhost:3000
TRUST_PROXY=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600

# AI (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LEGALOS_AI_MODEL=gpt-4o-mini

# Object storage (required in production when LEGALOS_REQUIRE_S3=true)
S3_BUCKET=
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# Provider credentials — licensed APIs only
ECOURTS_BASE_URL=
ECOURTS_CLIENT_ID=
ECOURTS_CLIENT_SECRET=
SCC_ONLINE_API_KEY=
MANUPATRA_API_KEY=

# Optional WOXOX host bridge
WOXOX_HOST_API_URL=

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1/legal
NEXT_PUBLIC_LEGALOS_BEARER_TOKEN=demo
NEXT_PUBLIC_WORKSPACE_ID=000000000000000000000001
NEXT_PUBLIC_ALLOW_MOCKS=true
